# ─── OpenRouter API key ───────────────────────────────────
# Get yours free at https://openrouter.ai/
# IMPORTANT: never commit the real .env file to git.
# The key must stay on the backend — never in frontend JS.
OPENROUTER_API_KEY=your_key_here

# ─── Free model selection ─────────────────────────────────
# Browse free models at https://openrouter.ai/models?q=free
# Examples:
#   mistralai/mistral-7b-instruct:free
#   meta-llama/llama-3.2-3b-instruct:free
#   google/gemma-3-1b-it:free
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ─── Server port ──────────────────────────────────────────
# Default 8080 matches the Python server (run one at a time)
PORT=8080

# ─── Remote display sync storage (recommended for Vercel) ─────────────
# Optional but recommended. Without this, Vercel may only keep sync state
# in temporary function memory, which can reset between cold starts.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
